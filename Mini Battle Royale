<!DOCTYPE html>
<html lang="it">
<head>

<meta charset="UTF-8">

<!-- BLOCCO ZOOM MOBILE -->
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">

<title>Mini Battle Royale</title>

<style>

html,body{
margin:0;
padding:0;
overflow:hidden;
background:black;
touch-action:none;
}

canvas{
display:block;
}

#ui{
position:absolute;
top:10px;
left:10px;
color:white;
font-family:Arial;
font-size:18px;
}

#controls{
position:absolute;
bottom:20px;
left:20px;
}

button{
width:60px;
height:60px;
font-size:25px;
margin:5px;
border:none;
border-radius:10px;
background:rgba(255,255,255,0.3);
color:white;
}

#actions{
position:absolute;
bottom:20px;
right:20px;
}

</style>

</head>
<body>

<div id="ui">
<div id="hp">HP:100</div>
<div id="storm">Storm:200</div>
</div>

<!-- FRECCETTE MOVIMENTO -->

<div id="controls">

<div>
<button id="up">⬆️</button>
</div>

<div>
<button id="left">⬅️</button>
<button id="down">⬇️</button>
<button id="right">➡️</button>
</div>

</div>

<!-- AZIONI -->

<div id="actions">

<button id="jump">🦘</button>
<button id="shoot">🔫</button>

</div>

<script src="https://cdn.jsdelivr.net/npm/three@0.152.2/build/three.min.js"></script>

<script>

////////////////////////////////////////////////////////
// SCENA
////////////////////////////////////////////////////////

const scene = new THREE.Scene()

const camera = new THREE.PerspectiveCamera(
75,
window.innerWidth/window.innerHeight,
0.1,
1000
)

const renderer = new THREE.WebGLRenderer({antialias:true})

renderer.setSize(window.innerWidth,window.innerHeight)

document.body.appendChild(renderer.domElement)

////////////////////////////////////////////////////////
// LUCE
////////////////////////////////////////////////////////

const light = new THREE.DirectionalLight(0xffffff,1)

light.position.set(50,100,50)

scene.add(light)

////////////////////////////////////////////////////////
// TERRENO
////////////////////////////////////////////////////////

const groundGeo = new THREE.PlaneGeometry(500,500)

const groundMat = new THREE.MeshLambertMaterial({color:0x228822})

const ground = new THREE.Mesh(groundGeo,groundMat)

ground.rotation.x = -Math.PI/2

scene.add(ground)

////////////////////////////////////////////////////////
// PLAYER
////////////////////////////////////////////////////////

const playerGeo = new THREE.BoxGeometry(2,4,2)

const playerMat = new THREE.MeshLambertMaterial({color:0x00aaff})

const player = new THREE.Mesh(playerGeo,playerMat)

player.position.y=2

scene.add(player)

camera.position.set(0,6,10)

////////////////////////////////////////////////////////
// SALTO
////////////////////////////////////////////////////////

let velocityY=0
let onGround=true

function jump(){

if(onGround){

velocityY=0.25
onGround=false

}

}

////////////////////////////////////////////////////////
// MOVIMENTO TOUCH
////////////////////////////////////////////////////////

const move={up:false,down:false,left:false,right:false}

function bindButton(id,dir){

const b=document.getElementById(id)

b.ontouchstart=()=>move[dir]=true
b.ontouchend=()=>move[dir]=false

}

bindButton("up","up")
bindButton("down","down")
bindButton("left","left")
bindButton("right","right")

////////////////////////////////////////////////////////
// SPARO
////////////////////////////////////////////////////////

const bullets=[]

function shoot(){

const geo = new THREE.SphereGeometry(0.3)

const mat = new THREE.MeshBasicMaterial({color:0xffff00})

const bullet = new THREE.Mesh(geo,mat)

bullet.position.copy(player.position)

bullet.velocity=new THREE.Vector3(0,0,-1)

bullets.push(bullet)

scene.add(bullet)

}

document.getElementById("shoot").onclick=shoot
document.getElementById("jump").onclick=jump

////////////////////////////////////////////////////////
// BOT
////////////////////////////////////////////////////////

const bots=[]

function spawnBot(){

const geo = new THREE.BoxGeometry(2,4,2)

const mat = new THREE.MeshLambertMaterial({color:0xff0000})

const bot = new THREE.Mesh(geo,mat)

bot.position.set(
Math.random()*100-50,
2,
Math.random()*100-50
)

bots.push(bot)

scene.add(bot)

}

for(let i=0;i<8;i++) spawnBot()

////////////////////////////////////////////////////////
// STORM
////////////////////////////////////////////////////////

let stormRadius=200

function updateStorm(){

stormRadius-=0.02

document.getElementById("storm").innerText="Storm:"+Math.floor(stormRadius)

const dist=Math.sqrt(
player.position.x*player.position.x+
player.position.z*player.position.z
)

if(dist>stormRadius){

playerHP-=0.1

}

}

////////////////////////////////////////////////////////
// STATS
////////////////////////////////////////////////////////

let playerHP=100

////////////////////////////////////////////////////////
// LOOP
////////////////////////////////////////////////////////

function animate(){

requestAnimationFrame(animate)

////////////////////////////////////////////////////////
// MOVIMENTO PLAYER
////////////////////////////////////////////////////////

if(move.up) player.position.z-=0.3
if(move.down) player.position.z+=0.3
if(move.left) player.position.x-=0.3
if(move.right) player.position.x+=0.3

////////////////////////////////////////////////////////
// SALTO FISICA
////////////////////////////////////////////////////////

velocityY-=0.01
player.position.y+=velocityY

if(player.position.y<=2){

player.position.y=2
velocityY=0
onGround=true

}

////////////////////////////////////////////////////////
// BULLETS
////////////////////////////////////////////////////////

bullets.forEach(b=>{
b.position.add(b.velocity)
})

////////////////////////////////////////////////////////
// BOT AI
////////////////////////////////////////////////////////

bots.forEach(bot=>{

const dir=new THREE.Vector3()

dir.subVectors(player.position,bot.position)

const dist=dir.length()

dir.normalize()

bot.position.add(dir.multiplyScalar(0.03))

if(dist<8){

playerHP-=0.03

}

})

////////////////////////////////////////////////////////
// STORM
////////////////////////////////////////////////////////

updateStorm()

////////////////////////////////////////////////////////
// CAMERA FOLLOW
////////////////////////////////////////////////////////

camera.position.x=player.position.x
camera.position.z=player.position.z+10
camera.lookAt(player.position)

////////////////////////////////////////////////////////

renderer.render(scene,camera)

}

animate()

////////////////////////////////////////////////////////
// FULLSCREEN AUTOMATICO
////////////////////////////////////////////////////////

document.body.addEventListener("click",()=>{

if(document.fullscreenElement==null){

document.body.requestFullscreen()

}

})

</script>

</body>
</html>
